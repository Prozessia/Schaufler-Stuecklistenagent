# Azure OpenAI (DSGVO-konform, EU-Region)
# Region: Sweden Central — DSGVO/Data Residency EU
AZURE_OPENAI_KEY=<your-azure-openai-key>
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT_MAIN=gpt-5.4
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-5.4

# Allgemein
LOG_LEVEL=INFO
MAX_LLM_RETRIES=3

# CORS — comma-separated list of allowed origins
# Default (if unset): http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# API key authentication
# Leave empty to disable auth in development
API_KEY=

# Login authentication (MVP local credentials)
LOGIN_AUTH_ENABLED=true
LOGIN_ADMIN_USER=admin
LOGIN_ADMIN_PASSWORD=admin

# Session cookie settings
SESSION_COOKIE_NAME=bom_session
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_SECURE=false