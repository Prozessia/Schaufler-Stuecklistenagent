# ----------------------------------------------------------------------------
# Production .env for VPS deployment.  Copy to ".env" and fill in real values.
#   cp .env.deploy.example .env  &&  nano .env
# ----------------------------------------------------------------------------

# --- Public domain (DNS A-record must point at this VPS) --------------------
DOMAIN=stuecklistenagent.prozessia.space
ACME_EMAIL=admin@prozessia.de          # for Let's Encrypt / Caddy TLS (anpassen)

# --- Azure OpenAI (DSGVO-konform, EU-Region) -------------------------------
AZURE_OPENAI_KEY=4Jv9kXhQdPXXe59iz8piUJKV1x3qYeg6M8euCv7sRXlZ4hX1Pck3JQQJ99BKACfhMk5XJ3w3AAABACOGedZg
AZURE_OPENAI_ENDPOINT=https://n8n-sweden-prozessia.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_MAIN=gpt-4o
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o

# --- Login (Review-Dashboard) ----------------------------------------------
LOGIN_AUTH_ENABLED=true
LOGIN_ADMIN_USER=admin
LOGIN_ADMIN_PASSWORD=change-me-please   # CHANGE THIS before going live
LOGIN_ALLOW_DEFAULT_ADMIN=false         # muss in Produktion false sein

# --- API key (leave EMPTY — cookie login handles auth) ---------------------
API_KEY=

# CORS_ORIGINS is set automatically to https://$DOMAIN by docker-compose.prod.yml.

LOG_LEVEL=INFO
MAX_LLM_RETRIES=3
